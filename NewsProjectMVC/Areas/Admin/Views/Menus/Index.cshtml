@model IEnumerable<NewsProjectMVC.Models.Db.Menu>

@{
    var parent = ViewBag.Parent as NewsProjectMVC.Models.Db.Menu;
    ViewData["Title"] = "Menus";
    //If the parent is defined get the title from the parent and pass it to the SubTitle key
    if (parent != null)
    {
        ViewData["SubTitle"] = parent.Title;

    }
    else
    {
        ViewData["SubTitle"] = "";
    }


}

<h1>Index</h1>

<p>
    <a href="/Admin/Menus/Create" class="btn btn-outline-primary">Add To Main Menu</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Link)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ParentId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Priority)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Title)
            </td>
            <td>
                @Html.DisplayFor(model => item.Link)
            </td>
            <td>
                @Html.DisplayFor(model => item.ParentId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Priority)
            </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" data-bs-toggle="tooltip" title="Edit" class="btn btn-link btn-primary btn-lg">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a href="/admin/menus/index/@item.Id" data-bs-toggle="tooltip" title="Sub Menus" class="btn btn-link btn-primary btn-lg">
                        <i class="fas fa-list"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" data-bs-toggle="tooltip" title="Delete" class="btn btn-link btn-danger btn-lg">
                        <i class="fas fa-times-circle"></i>
                    </a>
            </td>
        </tr>
}
    </tbody>
</table>
